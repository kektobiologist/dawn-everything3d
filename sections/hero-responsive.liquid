{{ 'section-hero-responsive.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #Hero-{{ section.id }} {
    --hero-height-mobile: {{ section.settings.mobile_height }}vh;
    --hero-height-desktop: {{ section.settings.desktop_height }}vh;
  }

  #Hero-{{ section.id }} .hero-responsive__media::after {
    opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
  }
{%- endstyle -%}

{%- assign slide_count = 0 -%}
{%- for block in section.blocks -%}
  {%- if block.type == 'image_slide' -%}
    {%- if block.settings.image != blank or block.settings.asset_image != blank -%}
      {%- assign slide_count = slide_count | plus: 1 -%}
    {%- endif -%}
  {%- endif -%}
{%- endfor -%}

<div
  id="Hero-{{ section.id }}"
  class="hero-responsive hero-responsive--{{ section.settings.desktop_layout }}{% if slide_count > 0 %} hero-responsive--has-slides{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}"
>
  {%- comment -%} Mobile: stacked layout - image then content below {%- endcomment -%}
  <div class="hero-responsive__mobile">
    <div class="hero-responsive__media-wrapper" data-hero-carousel>
      {%- if slide_count > 0 -%}
        <div class="hero-responsive__slides">
          {%- assign rendered_slide_index = 0 -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'image_slide' -%}
              {%- if block.settings.image != blank or block.settings.asset_image != blank -%}
                <div class="hero-responsive__slide{% if rendered_slide_index == 0 %} is-active{% endif %}" {{ block.shopify_attributes }}>
                  {%- if block.settings.image != blank -%}
                    {{
                      block.settings.image
                      | image_url: width: 1500
                      | image_tag:
                        widths: '375, 550, 750, 1000, 1500',
                        sizes: '100vw',
                        loading: 'eager',
                        fetchpriority: 'high',
                        class: 'hero-responsive__image'
                    }}
                  {%- else -%}
                    <img
                      src="{{ block.settings.asset_image | asset_url }}"
                      alt="{{ block.settings.alt_text | escape }}"
                      class="hero-responsive__image"
                      loading="eager"
                      fetchpriority="high"
                    >
                  {%- endif -%}
                </div>
                {%- assign rendered_slide_index = rendered_slide_index | plus: 1 -%}
              {%- endif -%}
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- elsif section.settings.mobile_image != blank -%}
        {{
          section.settings.mobile_image
          | image_url: width: 1500
          | image_tag:
            widths: '375, 550, 750, 1000, 1500',
            sizes: '100vw',
            loading: 'eager',
            fetchpriority: 'high',
            class: 'hero-responsive__image'
        }}
      {%- elsif section.settings.desktop_image != blank -%}
        {{
          section.settings.desktop_image
          | image_url: width: 1500
          | image_tag:
            widths: '375, 550, 750, 1000, 1500',
            sizes: '100vw',
            loading: 'eager',
            fetchpriority: 'high',
            class: 'hero-responsive__image'
        }}
      {%- else -%}
        <div class="hero-responsive__placeholder">
          {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
        </div>
      {%- endif -%}
      {%- if section.settings.show_overlay -%}
        <div class="hero-responsive__overlay"></div>
      {%- endif -%}
    </div>

    {%- if section.settings.heading != blank or section.settings.subheading != blank or section.settings.button_label != blank -%}
      <div class="hero-responsive__content-mobile color-{{ section.settings.color_scheme }}">
        {%- if section.settings.heading != blank -%}
          <h1 class="hero-responsive__heading hero-responsive__heading--{{ section.settings.mobile_heading_size }}">
            {{ section.settings.heading }}
          </h1>
        {%- endif -%}

        {%- if section.settings.subheading != blank -%}
          <p class="hero-responsive__subheading">
            {{ section.settings.subheading }}
          </p>
        {%- endif -%}

        {%- if section.settings.button_label != blank -%}
          <a
            href="{{ section.settings.button_link }}"
            class="button button--primary hero-responsive__button"
          >
            {{ section.settings.button_label }}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>

  {%- comment -%} Desktop: image with overlaid or split content {%- endcomment -%}
  <div class="hero-responsive__desktop">
    <div class="hero-responsive__desktop-inner">
      <div class="hero-responsive__media" data-hero-carousel>
        {%- if slide_count > 0 -%}
          <div class="hero-responsive__slides">
            {%- assign rendered_slide_index = 0 -%}
            {%- for block in section.blocks -%}
              {%- if block.type == 'image_slide' -%}
                {%- if block.settings.image != blank or block.settings.asset_image != blank -%}
                  <div class="hero-responsive__slide{% if rendered_slide_index == 0 %} is-active{% endif %}" {{ block.shopify_attributes }}>
                    {%- if block.settings.image != blank -%}
                      {{
                        block.settings.image
                        | image_url: width: 2000
                        | image_tag:
                          widths: '750, 1000, 1500, 2000',
                          sizes: '(min-width: 750px) 50vw, 100vw',
                          loading: 'eager',
                          fetchpriority: 'high',
                          class: 'hero-responsive__image'
                      }}
                    {%- else -%}
                      <img
                        src="{{ block.settings.asset_image | asset_url }}"
                        alt="{{ block.settings.alt_text | escape }}"
                        class="hero-responsive__image"
                        loading="eager"
                        fetchpriority="high"
                      >
                    {%- endif -%}
                  </div>
                  {%- assign rendered_slide_index = rendered_slide_index | plus: 1 -%}
                {%- endif -%}
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- elsif section.settings.desktop_image != blank -%}
          {{
            section.settings.desktop_image
            | image_url: width: 3840
            | image_tag:
              widths: '1000, 1500, 2000, 2500, 3000, 3840',
              sizes: '100vw',
              loading: 'eager',
              fetchpriority: 'high',
              class: 'hero-responsive__image'
          }}
        {%- elsif section.settings.mobile_image != blank -%}
          {{
            section.settings.mobile_image
            | image_url: width: 3840
            | image_tag:
              widths: '1000, 1500, 2000, 2500, 3000, 3840',
              sizes: '100vw',
              loading: 'eager',
              fetchpriority: 'high',
              class: 'hero-responsive__image'
          }}
        {%- else -%}
          <div class="hero-responsive__placeholder">
            {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
        {%- endif -%}
        {%- if section.settings.show_overlay -%}
          <div class="hero-responsive__overlay"></div>
        {%- endif -%}
      </div>

    {%- if section.settings.heading != blank or section.settings.subheading != blank or section.settings.button_label != blank -%}
      <div class="hero-responsive__content-desktop color-{{ section.settings.color_scheme }}">
        <div class="hero-responsive__content-inner">
          {%- if section.settings.heading != blank -%}
            <h1 class="hero-responsive__heading hero-responsive__heading--{{ section.settings.desktop_heading_size }}">
              {{ section.settings.heading }}
            </h1>
          {%- endif -%}

          {%- if section.settings.subheading != blank -%}
            <p class="hero-responsive__subheading">
              {{ section.settings.subheading }}
            </p>
          {%- endif -%}

          {%- if section.settings.button_label != blank -%}
            <a
              href="{{ section.settings.button_link }}"
              class="button button--primary hero-responsive__button"
            >
              {{ section.settings.button_label }}
            </a>
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}
    </div>
  </div>
</div>

{%- if slide_count > 1 -%}
  <script>
    (() => {
      const root = document.getElementById('Hero-{{ section.id }}');
      if (!root) return;

      root.querySelectorAll('[data-hero-carousel]').forEach((carousel) => {
        const slides = carousel.querySelectorAll('.hero-responsive__slide');
        if (slides.length < 2) return;

        let activeIndex = 0;
        setInterval(() => {
          slides[activeIndex].classList.remove('is-active');
          activeIndex = (activeIndex + 1) % slides.length;
          slides[activeIndex].classList.add('is-active');
        }, 4000);
      });
    })();
  </script>
{%- endif -%}

{% schema %}
{
  "name": "Hero (Responsive)",
  "tag": "section",
  "class": "section-hero-responsive",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "select",
      "id": "desktop_layout",
      "options": [
        { "value": "overlay", "label": "Image with text overlay" },
        { "value": "split", "label": "Split image and text" }
      ],
      "default": "overlay",
      "label": "Desktop layout"
    },
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop image",
      "info": "Recommended: 1920x1080 or larger"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image",
      "info": "Recommended: 750x1000 or taller. Falls back to desktop image if not set."
    },
    {
      "type": "range",
      "id": "desktop_height",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "label": "Desktop height",
      "default": 80
    },
    {
      "type": "range",
      "id": "mobile_height",
      "min": 30,
      "max": 80,
      "step": 5,
      "unit": "vh",
      "label": "Mobile image height",
      "default": 50
    },
    {
      "type": "header",
      "content": "Overlay"
    },
    {
      "type": "checkbox",
      "id": "show_overlay",
      "default": false,
      "label": "Show overlay"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "label": "Overlay opacity",
      "default": 30
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "desktop_heading_size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" },
        { "value": "hxl", "label": "Extra large" }
      ],
      "default": "h0",
      "label": "Desktop heading size"
    },
    {
      "type": "select",
      "id": "mobile_heading_size",
      "options": [
        { "value": "h3", "label": "Extra small" },
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h2",
      "label": "Mobile heading size"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "image_slide",
      "name": "Image slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "asset_image",
          "label": "Theme asset filename",
          "info": "Optional fallback for developer-managed assets, e.g. hero1-figurine.png"
        },
        {
          "type": "text",
          "id": "alt_text",
          "label": "Alt text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero (Responsive)"
    }
  ]
}
{% endschema %}
