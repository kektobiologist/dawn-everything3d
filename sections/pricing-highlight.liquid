{{ 'section-pricing-highlight.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="pricing-highlight">
  <div class="page-width section-{{ section.id }}-padding">
    <div class="pricing-highlight__card{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      {%- if section.settings.eyebrow != blank -%}
        <p class="pricing-highlight__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}

      {%- if section.settings.price != blank -%}
        <p class="pricing-highlight__price">{{ section.settings.price | escape }}</p>
      {%- endif -%}

      {%- if section.settings.unit != blank -%}
        <p class="pricing-highlight__unit">{{ section.settings.unit | escape }}</p>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <ul class="pricing-highlight__details">
          {%- for block in section.blocks -%}
            <li class="pricing-highlight__detail" {{ block.shopify_attributes }}>
              {{ block.settings.text | escape }}
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}

      {%- if section.settings.button_label != blank -%}
        <a
          href="{{ section.settings.button_link }}"
          class="pricing-highlight__cta"
          {% if section.settings.open_in_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}
        >
          {%- if section.settings.show_whatsapp_icon -%}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512">
              <path d="M380.9 97.1C339 55.1 283.2 32 223.9 32c-122.4 0-222 99.6-222 222 0 39.1 10.2 77.3 29.6 111L0 480l117.7-30.9c32.4 17.7 68.9 27 106.1 27h.1c122.3 0 224.1-99.6 224.1-222 0-59.3-25.2-115-67.1-157zm-157 341.6c-33.2 0-65.7-8.9-94-25.7l-6.7-4-69.8 18.3L72 359.2l-4.4-7c-18.5-29.4-28.2-63.3-28.2-98.2 0-101.7 82.8-184.5 184.6-184.5 49.3 0 95.6 19.2 130.4 54.1 34.8 34.9 56.2 81.2 56.1 130.5 0 101.8-84.9 184.6-186.6 184.6zm101.2-138.2c-5.5-2.8-32.8-16.2-37.9-18-5.1-1.9-8.8-2.8-12.5 2.8-3.7 5.6-14.3 18-17.6 21.8-3.2 3.7-6.5 4.2-12 1.4-32.6-16.3-54-29.1-75.5-66-5.7-9.8 5.7-9.1 16.3-30.3 1.8-3.7 .9-6.9-.5-9.7-1.4-2.8-12.5-30.1-17.1-41.2-4.5-10.8-9.1-9.3-12.5-9.5-3.2-.2-6.9-.2-10.6-.2-3.7 0-9.7 1.4-14.8 6.9-5.1 5.6-19.4 19-19.4 46.3 0 27.3 19.9 53.7 22.6 57.4 2.8 3.7 39.1 59.7 94.8 83.8 35.2 15.2 49 16.5 66.6 13.9 10.7-1.6 32.8-13.4 37.4-26.4 4.6-13 4.6-24.1 3.2-26.4-1.3-2.5-5-3.9-10.5-6.6z"/>
            </svg>
          {%- endif -%}
          {{ section.settings.button_label | escape }}
        </a>
      {%- endif -%}

      {%- if section.settings.note != blank -%}
        <p class="pricing-highlight__note">{{ section.settings.note | escape }}</p>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Pricing Highlight",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Simple Pricing"
    },
    {
      "type": "text",
      "id": "price",
      "label": "Price",
      "default": "₹499"
    },
    {
      "type": "text",
      "id": "unit",
      "label": "Unit text",
      "default": "per nameplate, inclusive of GST"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Get a Quote on WhatsApp"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "checkbox",
      "id": "open_in_new_tab",
      "label": "Open in new tab",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_whatsapp_icon",
      "label": "Show WhatsApp icon",
      "default": true
    },
    {
      "type": "text",
      "id": "note",
      "label": "Note text",
      "default": "No hidden fees. Volume discounts available for 50+ plates."
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 52
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 52
    }
  ],
  "blocks": [
    {
      "type": "detail",
      "name": "Detail",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Detail text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Pricing Highlight"
    }
  ]
}
{% endschema %}
