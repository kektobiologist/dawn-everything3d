{%- style -%}
  .render-vs-print-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  .render-vs-print-{{ section.id }} .render-vs-print__inner {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
  }

  .render-vs-print__header {
    max-width: 860px;
    margin: 0 auto 2.4rem;
    text-align: center;
  }

  .render-vs-print__heading {
    margin: 0;
    color: rgb(var(--color-foreground));
  }

  .render-vs-print__subheading {
    margin: 0.9rem 0 0;
    color: rgba(var(--color-foreground), 0.76);
    font-size: 1.7rem;
    line-height: 1.45;
  }

  .render-vs-print__grid {
    display: grid;
    gap: 1.6rem;
  }

  .render-vs-print__card {
    display: grid;
    gap: 1.5rem;
    padding: 1.4rem;
    border: 0.1rem solid rgba(var(--color-foreground), 0.1);
    border-radius: 0.8rem;
    background: rgb(var(--color-background));
    box-shadow: 0 1.2rem 3rem rgba(var(--color-foreground), 0.07);
  }

  .render-vs-print__comparison {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 1rem;
    align-items: center;
  }

  .render-vs-print__media {
    min-width: 0;
  }

  .render-vs-print__label {
    display: inline-flex;
    margin: 0 0 0.8rem;
    padding: 0.35rem 1.1rem;
    border-radius: 0.5rem;
    background: #1f3425;
    color: #fff;
    font-size: 1.2rem;
    font-weight: 700;
    line-height: 1.2;
  }

  .render-vs-print__image-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 22rem;
    overflow: hidden;
    border-radius: 0.6rem;
    background: #fbfaf7;
  }

  .render-vs-print__image-wrap img {
    display: block;
    width: 100%;
    height: 100%;
    max-height: 31rem;
    object-fit: contain;
  }

  .render-vs-print__arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    color: #b9a371;
    font-size: 2.8rem;
    line-height: 1;
    transform: rotate(90deg);
  }

  .render-vs-print__note {
    margin: 0;
    padding: 1rem 1.2rem;
    border-radius: 0.6rem;
    background: #f4efe4;
    color: rgba(var(--color-foreground), 0.78);
    font-size: 1.4rem;
    line-height: 1.45;
  }

  .render-vs-print__footer {
    max-width: 820px;
    margin: 1.8rem auto 0;
    text-align: center;
    color: rgba(var(--color-foreground), 0.72);
    font-size: 1.45rem;
    line-height: 1.45;
  }

  @media screen and (min-width: 750px) {
    .render-vs-print-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }

    .render-vs-print__header {
      margin-bottom: 3rem;
    }

    .render-vs-print__subheading {
      font-size: 1.9rem;
    }

    .render-vs-print__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1.8rem;
    }

    .render-vs-print__card--featured {
      grid-column: 1 / -1;
      padding: 1.8rem;
    }

    .render-vs-print__comparison {
      grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
      gap: 1.6rem;
    }

    .render-vs-print__arrow {
      transform: none;
    }

    .render-vs-print__card--featured .render-vs-print__image-wrap {
      min-height: 32rem;
    }
  }
{%- endstyle -%}

<div class="render-vs-print render-vs-print-{{ section.id }} color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
    <div class="render-vs-print__inner">
      <div class="render-vs-print__header">
        <h2 class="render-vs-print__heading {{ section.settings.heading_size }}">
          {{ section.settings.heading | escape }}
        </h2>
        {%- if section.settings.subheading != blank -%}
          <p class="render-vs-print__subheading">{{ section.settings.subheading | escape }}</p>
        {%- endif -%}
      </div>

      <div class="render-vs-print__grid">
        {%- if section.blocks.size > 0 -%}
          {%- for block in section.blocks -%}
            <article class="render-vs-print__card{% if block.settings.featured %} render-vs-print__card--featured{% endif %}" {{ block.shopify_attributes }}>
              <div class="render-vs-print__comparison">
                <div class="render-vs-print__media">
                  <span class="render-vs-print__label">{{ block.settings.render_label | escape }}</span>
                  <div class="render-vs-print__image-wrap">
                    {%- if block.settings.render_image != blank -%}
                      {{
                        block.settings.render_image
                        | image_url: width: 900
                        | image_tag:
                          loading: 'lazy',
                          widths: '300, 450, 600, 750, 900',
                          sizes: '(min-width: 750px) 45vw, 92vw',
                          alt: block.settings.render_label
                      }}
                    {%- endif -%}
                  </div>
                </div>

                <div class="render-vs-print__arrow" aria-hidden="true">&rarr;</div>

                <div class="render-vs-print__media">
                  <span class="render-vs-print__label">{{ block.settings.print_label | escape }}</span>
                  <div class="render-vs-print__image-wrap">
                    {%- if block.settings.print_image != blank -%}
                      {{
                        block.settings.print_image
                        | image_url: width: 900
                        | image_tag:
                          loading: 'lazy',
                          widths: '300, 450, 600, 750, 900',
                          sizes: '(min-width: 750px) 45vw, 92vw',
                          alt: block.settings.print_label
                      }}
                    {%- endif -%}
                  </div>
                </div>
              </div>
              {%- if block.settings.note != blank -%}
                <p class="render-vs-print__note">{{ block.settings.note | escape }}</p>
              {%- endif -%}
            </article>
          {%- endfor -%}
        {%- else -%}
          <article class="render-vs-print__card render-vs-print__card--featured">
            <div class="render-vs-print__comparison">
              <div class="render-vs-print__media">
                <span class="render-vs-print__label">AI Render</span>
                <div class="render-vs-print__image-wrap">
                  <img src="{{ 'render-vs-print-feature-render.png' | asset_url }}" alt="AI render preview of a couple figurine" width="390" height="350" loading="lazy">
                </div>
              </div>
              <div class="render-vs-print__arrow" aria-hidden="true">&rarr;</div>
              <div class="render-vs-print__media">
                <span class="render-vs-print__label">Final 3D Print</span>
                <div class="render-vs-print__image-wrap">
                  <img src="{{ 'render-vs-print-feature-print.png' | asset_url }}" alt="Final 3D printed couple figurine" width="365" height="370" loading="lazy">
                </div>
              </div>
            </div>
            <p class="render-vs-print__note">Overall look stays similar, but fine details are simplified for printing.</p>
          </article>

          <article class="render-vs-print__card">
            <div class="render-vs-print__comparison">
              <div class="render-vs-print__media">
                <span class="render-vs-print__label">AI Render</span>
                <div class="render-vs-print__image-wrap">
                  <img src="{{ 'render-vs-print-casual-render.png' | asset_url }}" alt="AI render preview of a casual couple figurine" width="245" height="245" loading="lazy">
                </div>
              </div>
              <div class="render-vs-print__arrow" aria-hidden="true">&rarr;</div>
              <div class="render-vs-print__media">
                <span class="render-vs-print__label">Final 3D Print</span>
                <div class="render-vs-print__image-wrap">
                  <img src="{{ 'render-vs-print-casual-print.png' | asset_url }}" alt="Final 3D printed casual couple figurine" width="290" height="270" loading="lazy">
                </div>
              </div>
            </div>
            <p class="render-vs-print__note">Pose may be adjusted slightly for stability.</p>
          </article>

          <article class="render-vs-print__card">
            <div class="render-vs-print__comparison">
              <div class="render-vs-print__media">
                <span class="render-vs-print__label">AI Render</span>
                <div class="render-vs-print__image-wrap">
                  <img src="{{ 'render-vs-print-wedding-render.png' | asset_url }}" alt="AI render preview of a traditional outfit couple figurine" width="215" height="255" loading="lazy">
                </div>
              </div>
              <div class="render-vs-print__arrow" aria-hidden="true">&rarr;</div>
              <div class="render-vs-print__media">
                <span class="render-vs-print__label">Final 3D Print</span>
                <div class="render-vs-print__image-wrap">
                  <img src="{{ 'render-vs-print-wedding-print.png' | asset_url }}" alt="Final 3D printed traditional outfit couple figurine" width="220" height="255" loading="lazy">
                </div>
              </div>
            </div>
            <p class="render-vs-print__note">Complex clothing patterns may be simplified.</p>
          </article>
        {%- endif -%}
      </div>

      {%- if section.settings.footer_text != blank -%}
        <p class="render-vs-print__footer">{{ section.settings.footer_text | escape }}</p>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Render vs Print",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "From AI Render to Final 3D Print"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h2",
          "label": "Small"
        },
        {
          "value": "h1",
          "label": "Medium"
        },
        {
          "value": "h0",
          "label": "Large"
        }
      ],
      "default": "h1",
      "label": "Heading size"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "AI renders are concept previews. Final figurines are adapted for real-world 3D printing."
    },
    {
      "type": "text",
      "id": "footer_text",
      "label": "Footer text",
      "default": "We always try to keep the likeness, outfit feel, and overall vibe as close as possible."
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 900,
      "max": 1400,
      "step": 20,
      "unit": "px",
      "label": "Max width",
      "default": 1160
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "comparison",
      "name": "Comparison",
      "settings": [
        {
          "type": "checkbox",
          "id": "featured",
          "label": "Featured full-width layout",
          "default": false
        },
        {
          "type": "text",
          "id": "render_label",
          "label": "Render label",
          "default": "AI Render"
        },
        {
          "type": "image_picker",
          "id": "render_image",
          "label": "Render image"
        },
        {
          "type": "text",
          "id": "print_label",
          "label": "Print label",
          "default": "Final 3D Print"
        },
        {
          "type": "image_picker",
          "id": "print_image",
          "label": "Print image"
        },
        {
          "type": "text",
          "id": "note",
          "label": "Note",
          "default": "Overall look stays similar, but fine details are simplified for printing."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Render vs Print"
    }
  ]
}
{% endschema %}
